{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/css/**",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/js/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "frontend/js/$1"
    },
    {
      "src": "/feed.html",
      "dest": "frontend/feed.html"
    },
    {
      "src": "/createpost.html",
      "dest": "frontend/createpost.html"
    },
    {
      "src": "/edit-post.html",
      "dest": "frontend/edit-post.html"
    },
    {
      "src": "/post.html",
      "dest": "frontend/post.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}